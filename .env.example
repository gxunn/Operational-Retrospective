# 首次登录账号（生产环境务必修改）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请改成至少12位的强密码
SESSION_SECRET=请改成一段至少32位的随机字符

# OpenAI（实际密钥只放在 .env，绝不要提交到代码仓库）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# 数据与时区
DATABASE_URL=sqlite:///./data/app.db
APP_TIMEZONE=Asia/Shanghai
REPORT_HOUR=10
REPORT_MINUTE=0
HOTSPOT_HOUR=9
HOTSPOT_MINUTE=0
MAX_UPLOAD_MB=30
COOKIE_SECURE=false

# 邮件。QQ/163 邮箱通常要填写“授权码”，不是网页登录密码
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=true
MAIL_FROM=
MAIL_FROM_NAME=自媒体每日复盘

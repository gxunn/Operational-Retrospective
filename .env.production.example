# 网站域名，不要写 http:// 或 https://
DOMAIN=report.example.com

# 首次管理员。请使用独立强密码
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请改成至少12位的强密码
SESSION_SECRET=请改成至少32位的随机字符

DATABASE_URL=sqlite:///./data/app.db
APP_TIMEZONE=Asia/Shanghai
REPORT_HOUR=10
REPORT_MINUTE=0
HOTSPOT_HOUR=9
HOTSPOT_MINUTE=0
MAX_UPLOAD_MB=30
COOKIE_SECURE=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=true
MAIL_FROM=
MAIL_FROM_NAME=自媒体每日复盘
